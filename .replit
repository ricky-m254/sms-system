modules = ["python-3.12", "nodejs-20", "web", "bash"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = ["freetype", "glibcLocales", "lcms2", "libimagequant", "libjpeg", "libtiff", "libwebp", "libxcrypt", "openjpeg", "tcl", "tk", "zlib"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend API"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd sms_frontend && npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Backend API"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd sms_backend && python manage.py runserver localhost:8000"

[[ports]]
localPort = 3000
externalPort = 80

[[ports]]
localPort = 5000
externalPort = 5000

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "cd sms_backend && python manage.py migrate --noinput && gunicorn --bind=0.0.0.0:3000 --workers=2 --timeout=120 config.wsgi:application"]
build = ["npm", "run", "build"]

[userenv]

[userenv.shared]
DJANGO_ALLOW_INSECURE_DEFAULTS = "true"
DJANGO_ALLOWED_HOSTS = ""
CORS_ALLOWED_ORIGINS = ""
CSRF_TRUSTED_ORIGINS = ""

[userenv.development]
DJANGO_DEBUG = "true"

[userenv.production]
DJANGO_DEBUG = "false"
DJANGO_SECURE_SSL_REDIRECT = "false"
