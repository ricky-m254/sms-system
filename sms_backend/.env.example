DJANGO_DEBUG=true
DJANGO_ALLOW_INSECURE_DEFAULTS=true
DJANGO_SECRET_KEY=change-me-before-production
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,demo.localhost
DJANGO_SECURE_SSL_REDIRECT=false
DJANGO_SESSION_COOKIE_SAMESITE=Lax
DJANGO_CSRF_COOKIE_SAMESITE=Lax
DJANGO_SECURE_HSTS_SECONDS=0
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=false
DJANGO_SECURE_HSTS_PRELOAD=false
DJANGO_SECURE_REFERRER_POLICY=strict-origin-when-cross-origin
TENANT_HEADER_NAME=X-Tenant-ID
TENANT_REQUIRE_HEADER=false
TENANT_ENFORCE_HEADER_MATCH=true
TENANT_ENFORCE_HOST_MATCH=true
TENANT_GUARD_API_PREFIX=/api/
MODULE_FOCUS_LOCK=false
MODULE_FOCUS_KEYS=FINANCE,STUDENTS,ACADEMICS,CORE
PLATFORM_DEFAULT_BASE_DOMAIN=localhost
PLATFORM_DEFAULT_TRIAL_DAYS=14
PLATFORM_BILLING_GRACE_DAYS=7
PLATFORM_MAINTENANCE_NOTIFY_CHANNELS=IN_APP,EMAIL

POSTGRES_DB=sms_school_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://demo.localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://demo.localhost:3000

COMMUNICATION_SMS_API_KEY=
COMMUNICATION_WHATSAPP_API_KEY=
COMMUNICATION_PUSH_SERVER_KEY=
COMMUNICATION_WEBHOOK_TOKEN=
COMMUNICATION_WEBHOOK_SHARED_SECRET=

FINANCE_PAYMENT_GATEWAY_PROVIDER=placeholder
FINANCE_PAYMENT_GATEWAY_API_KEY=
FINANCE_WEBHOOK_TOKEN=
FINANCE_WEBHOOK_SHARED_SECRET=
